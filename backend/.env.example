JWT_SECRET=super_secret_cyberpunk_dev_key_2026
ADMIN_USER=admin
ADMIN_PASS=cyberpunk_password

# Port the app is exposed on (default 80). Change if your ISP blocks 80.
# Players connect to http://your-ip:APP_PORT (port 80 = no port in URL)
APP_PORT=80

# Watchtower HTTP API — enables the manual check-for-updates button
# Generate a token: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
WATCHTOWER_API_TOKEN=change_me_to_a_strong_random_token

# DuckDNS — optional, only needed if using the duckdns service in docker-compose
# Get your token and subdomain at https://www.duckdns.org
DUCKDNS_SUBDOMAINS=yourname
DUCKDNS_TOKEN=your-duckdns-token

# Timezone for DuckDNS container and Watchtower schedule (e.g. America/New_York)
TZ=America/Chicago
