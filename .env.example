# ─── Admin Credentials ────────────────────────────────────────────────────────
# Username and password for the admin account.
# Change these before deploying — default credentials are publicly known.
ADMIN_USER=admin
ADMIN_PASS=cyberpunk_password

# ─── JWT Secret ───────────────────────────────────────────────────────────────
# Secret key used to sign admin session tokens.
# Generate a strong random value: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=change-me-to-a-long-random-string

# ─── Server ───────────────────────────────────────────────────────────────────
# Port the backend listens on. Docker maps this internally — no need to change.
PORT=5000

# ─── Secure Mode ──────────────────────────────────────────────────────────────
# Set to true to require players to register and log in with a password.
# When false (default), players connect with a username only.
SECURE_MODE=false
