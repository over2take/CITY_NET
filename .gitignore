# Node dependencies
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# Build outputs
dist/
build/

# SQLite databases
backend/*.db
backend/*.db.bak
backend/*.sqlite
backend/data/

# Backend environment and dev config
backend/.env
backend/nodemon.json

# Large archives
*.zip
*.rar
*.tar.gz

# IDE and OS files
.vscode/
.idea/
.DS_Store
Thumbs.db
.claude/
.agents/

# Tunnel Configs and Certificates
ngrok.yml
cert.pem
cloudflared/
cloudflared_token.txt
cloudflared.exe

# User Uploads
backend/uploads/

# Local asset source folders (not used by the app at runtime)
Images/
Computer sounds/
docs/

# Local launcher scripts (machine-specific, not needed in repo)
*.bat
*.ps1
# ...but the guided setup scripts ship with the project
!setup.ps1
!setup.sh
!setup.bat

# Frontend dev scripts and build artifacts
frontend/*.cjs
frontend/test.js
frontend/test_output.txt
frontend/src/*.bak

# Local .env backups (created when testing setup scripts)
*.env.bak
*.env.backup
